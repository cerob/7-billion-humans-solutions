-- 7 Billion Humans (2215) --
-- 54: Terrain Leveler --

a:
step n
mem1 = calc mem1 + c
if n != wall:
	jump a
endif
b:
pickup c
write mem1
drop
step s
if c == datacube:
	jump b
endif
c:
step nw
if w != wall:
	jump c
endif
d:
step e
mem2 = calc mem2 + c
if e == datacube:
	jump d
endif
mem2 = calc mem2 / 49
e:
pickup c
write mem2
drop
step w
jump e
