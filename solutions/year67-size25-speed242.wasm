-- 7 Billion Humans (2215) --
-- 67: Decimal Doubler --

step s
if s == button:
	a:
	listenfor ready
	step s
	step n
	tell everyone go
	jump a
endif
pickup c
step s
jump b
c:
listenfor go
pickup c
mem1 = calc myitem x 2
mem1 = calc mem1 + mem2
if mem1 > 9:
	mem1 = calc mem1 - 10
else:
	mem1 = calc mem1 - 0
endif
write mem1
b:
drop
tell e ready
mem2 = set 0
if e >= 5:
	mem2 = set 1
endif
jump c
